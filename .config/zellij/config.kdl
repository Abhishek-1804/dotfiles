keybinds {
    shared_except "locked" {
        unbind "Ctrl g"
    }
}

// Set secondary modifier to Shift+Ctrl
simplified_ui true
default_mode "normal"
mouse_mode true
pane_frames false
theme "catppuccin-mocha"

// Modifier configuration
keybinds {
    normal {
        bind "Ctrl Shift" {
            // Secondary modifier bindings
        }
    }
}
